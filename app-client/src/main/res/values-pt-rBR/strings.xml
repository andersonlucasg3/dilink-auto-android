    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Bem-vindo ao DiLink-Auto</string>
    <string name="onboarding_welcome_desc">Use os apps do seu telefone na tela do carro. Vamos configurar algumas permissões para tudo funcionar.</string>
