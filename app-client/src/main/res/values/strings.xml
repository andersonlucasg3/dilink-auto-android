    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Welcome to DiLink-Auto</string>
    <string name="onboarding_welcome_desc">Use your phone apps on your car\'s built-in screen. Let\'s set up a few permissions to make everything work.</string>
    <string name="onboarding_files_title">All Files Access</string>
    <string name="onboarding_files_desc">Deploys the virtual display server to your phone\'s storage. Without this, the car can\'t start screen mirroring.</string>
    <string name="onboarding_battery_title">Battery Optimization</string>
    <string name="onboarding_battery_desc">Keeps the connection alive when your screen is off. Without this, streaming stops whenever your phone sleeps.</string>
    <string name="onboarding_accessibility_title">Accessibility Service</string>
    <string name="onboarding_accessibility_desc">Lets the car\'s touchscreen control your phone. Without this, you\'ll see the screen but can\'t tap anything.</string>
    <string name="onboarding_notification_title">Notification Access</string>
    <string name="onboarding_notification_desc">Shows phone notifications on the car display. Without this, you\'ll miss calls and messages while driving.</string>
    <string name="onboarding_car_setup_title">Before You Connect</string>
    <string name="onboarding_car_setup_desc">Make sure everything is ready before connecting:</string>
