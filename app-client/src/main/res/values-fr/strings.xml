    <string name="onboarding_welcome_title">Bienvenue sur DiLink-Auto</string>
    <string name="onboarding_welcome_desc">Utilisez vos applis sur l\'écran de la voiture. Configurons quelques permissions pour que tout fonctionne.</string>
    <string name="onboarding_files_title">Accès à tous les fichiers</string>
    <string name="onboarding_files_desc">Déploie le serveur d\'affichage virtuel dans le stockage. Sans cela, la voiture ne peut pas démarrer la diffusion.</string>
    <string name="onboarding_battery_title">Optimisation de la batterie</string>
    <string name="onboarding_battery_desc">Maintient la connexion quand l\'écran est éteint. Sans cela, la diffusion s\'arrête en veille.</string>
    <string name="onboarding_accessibility_title">Service d\'accessibilité</string>
    <string name="onboarding_accessibility_desc">Permet à l\'écran de la voiture de contrôler le téléphone. Sans cela, vous verrez l\'écran sans pouvoir toucher.</string>
    <string name="onboarding_notification_title">Accès aux notifications</string>
    <string name="onboarding_notification_desc">Affiche les notifications du téléphone sur l\'écran de la voiture. Sans cela, vous manquerez appels et messages.</string>
