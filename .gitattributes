# Normalize line endings to LF for all text files
* text=auto

# Source code — always LF
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Shell scripts must be LF
gradlew text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.apk binary
*.jar binary
*.keystore binary
*.aar binary
